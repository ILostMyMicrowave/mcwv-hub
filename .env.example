# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mcwv_hub

# Session (must be at least 32 characters)
SESSION_SECRET=your-secret-key-here-min-32-chars

# External APIs (Pet Simulator 99)
PS99_API=https://api.ps99.com
CLAN_API=https://api.clan.example.com

# Bot Admin API (server-to-server; the Hub calls the bot, never the browser)
BOT_ADMIN_API_URL=http://localhost:10000
BOT_ADMIN_API_KEY=change-this-shared-secret

# Environment
NODE_ENV=development
